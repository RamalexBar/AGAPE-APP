# ── Entorno ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key

# ── JWT ──────────────────────────────────────────────────────────────
# IMPORTANTE: estos nombres deben coincidir EXACTAMENTE con env.js
# Usa strings aleatorios de 64+ caracteres (ej: openssl rand -base64 64)
JWT_ACCESS_SECRET=cambia_esto_minimo_64_caracteres_aleatorios_AAAA
JWT_REFRESH_SECRET=cambia_esto_otro_minimo_64_caracteres_aleatorios_BBBB
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Apple IAP (App Store Connect → My Apps → In-App Purchases) ───────
# App Store Connect → App → In-App Purchases → App-Specific Shared Secret
APPLE_IAP_SHARED_SECRET=tu_shared_secret_aqui

# ── Google Play Billing ───────────────────────────────────────────────
GOOGLE_PLAY_PACKAGE_NAME=com.agape.app
# Service Account JSON: Google Play Console → Setup → API access → Service account
# Opción A: ruta al archivo JSON
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/service-account.json
# Opción B: contenido inline (recomendado para Railway/Render)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── Firebase Push Notifications ──────────────────────────────────────
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ── URLs legales (deben ser públicas y accesibles vía HTTPS) ─────────
PRIVACY_POLICY_URL=https://tudominio.com/privacy
TERMS_OF_SERVICE_URL=https://tudominio.com/terms
