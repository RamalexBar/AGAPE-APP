{
  "expo": {
    "name": "Ágape",
    "slug": "agape",
    "version": "10.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "owner": "ramalexs-organization",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a14"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.agape.app",
      "buildNumber": "10",
      "infoPlist": {
        "NSCameraUsageDescription": "Ágape necesita acceso a la cámara para tomar fotos de perfil.",
        "NSPhotoLibraryUsageDescription": "Ágape necesita acceso a tus fotos para subir imágenes de perfil.",
        "NSLocationWhenInUseUsageDescription": "Ágape usa tu ubicación para encontrar personas cercanas.",
        "NSMicrophoneUsageDescription": "Ágape necesita el micrófono para las videollamadas.",
        "NSUserNotificationsUsageDescription": "Ágape necesita notificaciones para alertarte de nuevos matches y mensajes."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#0a0a14"
      },
      "package": "com.agape.app",
      "versionCode": 10,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": false
          },
          "android": {
            "newArchEnabled": false,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "51f4842b-a0d5-4c79-a2b1-22e24dd5db9c"
      }
    }
  }
}